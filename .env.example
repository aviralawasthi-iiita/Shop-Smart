# -----------------------------------------------------------------------------
# Shop-Smart - Example Environment Variables for Local Development
# -----------------------------------------------------------------------------
# Copy this file to .env or .env.local and adjust as needed.

# Database Configuration (matches local docker-compose.yml)
NEXT_PUBLIC_DB_HOST="localhost"
NEXT_PUBLIC_DB_USER="root"
NEXT_PUBLIC_DB_PASSWORD="password"
NEXT_PUBLIC_DB_NAME="shopsmart"
NEXT_PUBLIC_DB_PORT="5432"

# Prisma connection string (matches local docker-compose.yml)
DATABASE_URL="postgresql://root:password@localhost:5432/shopsmart?schema=public"

# Kafka Configuration (matches local docker-compose.yml)
KAFKA_BROKERS="localhost:9092"
# Leave SSL and SASL commented out or empty for local docker setup
# KAFKA_SSL="true"
# KAFKA_SASL_USERNAME=""
# KAFKA_SASL_PASSWORD=""

# API Keys and Secrets
GEMINI_API_KEY="your_gemini_api_key_here"
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY="your_google_maps_api_key_here"

# Email Configuration
SMTP_EMAIL="your_smtp_email@example.com"
SMTP_PASSWORD="your_smtp_password"

# Other Settings
NEXT_PUBLIC_BACKEND_URL="/api"
ENCRYPTION_KEY="your_32_character_encryption_key_here"
