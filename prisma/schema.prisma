generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Store {
  storeId         Int            @id @default(autoincrement())
  storeName       String         @default("ShopSmart")
  managerEmail    String         @unique
  storeLocation   String
  managerPassword String
  shopDomain      String?        @unique
  apiToken        String?
  webhookSecret   String?
  announcements   Announcement[]
  quietTimes      QuietTime[]
  shopifyProducts ShopifyProduct[]
  shopifyVariants ShopifyVariant[]
  shopifyInventoryLevels ShopifyInventoryLevel[]

  @@map("store")
}

model ShopifyProduct {
  id          String   @id
  storeId     Int
  title       String
  productType String?
  vendor      String?
  tags        String[]
  variants    ShopifyVariant[]
  store       Store    @relation(fields: [storeId], references: [storeId], onDelete: Cascade)

  @@unique([id, storeId])
  @@map("shopify_product")
}

model ShopifyVariant {
  id        String   @id
  productId String
  storeId   Int
  title     String
  price     String?
  product   ShopifyProduct @relation(fields: [productId], references: [id], onDelete: Cascade)
  store     Store          @relation(fields: [storeId], references: [storeId], onDelete: Cascade)
  inventoryLevels ShopifyInventoryLevel[]

  @@unique([id, storeId])
  @@map("shopify_variant")
}

model ShopifyInventoryLevel {
  id                String   @id
  variantId         String
  locationId        String
  storeId           Int
  availableQuantity Int      @default(0)
  variant           ShopifyVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  store             Store          @relation(fields: [storeId], references: [storeId], onDelete: Cascade)

  @@unique([variantId, locationId, storeId])
  @@map("shopify_inventory_level")
}

model User {
  userId     Int         @id @default(autoincrement())
  userEmail  String      @unique
  name       String
  password   String
  quietTimes QuietTime[]

  @@map("user_table")
}

model Announcement {
  id         Int      @id @default(autoincrement())
  title      String
  descrip    String?
  storeId    Int
  created_at DateTime @default(now())
  
  store      Store    @relation(fields: [storeId], references: [storeId])

  @@map("announcement")
}

model QuietTime {
  id         Int      @id @default(autoincrement())
  userId     Int
  storeId    Int
  date       DateTime
  timewindow String
  reason     String?
  status     String   @default("pending")
  
  user       User     @relation(fields: [userId], references: [userId])
  store      Store    @relation(fields: [storeId], references: [storeId])

  @@map("quiettime")
}

model OTP {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  code      String
  expiresAt DateTime

  @@map("otp")
}
